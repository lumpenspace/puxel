  "PixelShader": {
    "description": "Hero shader: an animated, Bayer-dithered field quantized to theme colors,\nrendered on a coarse pixel grid (WebGL). By default it absolutely fills its\nnearest positioned ancestor — drop it into any hero/panel as a background\nlayer (see <Splash shader>). Honors prefers-reduced-motion by holding a\nstatic frame. Degrades to nothing (transparent) without WebGL.",
    "props": [
      {
        "name": "block",
        "type": "boolean",
        "required": false,
        "defaultValue": null,
        "description": "Lay out as a normal block instead of filling the nearest positioned ancestor."
      },
