        "required": false,
        "defaultValue": null,
        "description": "4-color palette, dark → bright. Entries are any CSS color or a custom\nproperty name (\"--px-accent\"), resolved at the canvas. Defaults to the\ntheme's bg → surface → surface-2 → accent ramp."
      },
      {
        "name": "dissolved",
        "type": "boolean",
        "required": false,
        "defaultValue": "false",
        "description": "Dissolve the field cell-by-cell (ordered dither), and back."
      },
      {
        "name": "dissolveMs",
