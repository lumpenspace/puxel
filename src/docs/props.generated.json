        "required": false,
        "defaultValue": "900",
        "description": "Duration of the dissolve transition."
      },
      {
        "name": "onDissolveEnd",
        "type": "((dissolved: boolean) => void)",
        "required": false,
        "defaultValue": null,
        "description": "Fires when a dissolve (or re-materialize) transition completes."
      },
      {
        "name": "pattern",
        "type": "\"plasma\" | \"ripple\" | \"waves\"",
        "required": false,
        "defaultValue": "plasma",
        "description": ""
      },
      {
        "name": "paused",
        "type": "boolean",
        "required": false,
        "defaultValue": "false",
